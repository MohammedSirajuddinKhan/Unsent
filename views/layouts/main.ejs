<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || "Unsent." %></title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <meta name="description" content="<%= description || 'Unsent.' %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <style>
      :root {
        --font-sans: 'Poppins', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
        --ink: #2f004f;
        --coral: #eabfcb;
        --sun: #c191a1;
        --blue: #a4508b;
        --mint: #5f0a87;
        --page: #fbf7fa;
        --card: #ffffff;
        --border: rgba(100, 10, 135, 0.14);
      }

      body {
        font-family: var(--font-sans);
        position: relative;
        background:
          radial-gradient(circle at top left, rgba(234, 191, 203, 0.7), transparent 32%),
          radial-gradient(circle at top right, rgba(95, 10, 135, 0.18), transparent 26%),
          linear-gradient(135deg, #f7dbe6 0%, #f1e4ff 42%, #f8effb 72%, #e9ddfb 100%);
        color: var(--ink);
        min-height: 100vh;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: auto;
        pointer-events: none;
        z-index: -1;
        filter: blur(12px);
      }

      body::before {
        top: 7rem;
        left: -3rem;
        width: 14rem;
        height: 14rem;
        border-radius: 50%;
        background: rgba(164, 80, 139, 0.14);
      }

      body::after {
        right: -2.5rem;
        bottom: 3rem;
        width: 16rem;
        height: 16rem;
        border-radius: 50%;
        background: rgba(95, 10, 135, 0.12);
      }

      .navbar-brand {
        letter-spacing: -0.02em;
      }

      .navbar {
        background: linear-gradient(90deg, var(--mint), var(--ink)) !important;
      }

      .navbar .container {
        max-width: 1080px;
      }

      .navbar .navbar-brand,
      .navbar .text-muted,
      .navbar .btn {
        color: #ffffff;
      }

      .navbar .btn-outline-secondary {
        border-color: rgba(255, 255, 255, 0.5);
        color: #ffffff;
      }

      .navbar .btn-outline-secondary:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.65);
        color: #ffffff;
      }

      .navbar .btn-primary {
        background: var(--coral);
        border-color: var(--coral);
        color: var(--ink);
      }

      .card {
        background: rgba(255, 247, 252, 0.82);
        backdrop-filter: blur(8px);
        border-color: var(--border);
        box-shadow: 0 0.5rem 1.25rem rgba(47, 0, 79, 0.08);
        border-radius: 1rem;
      }

      .card-body {
        padding: 1.25rem;
      }

      .card-header,
      .card-footer {
        background: rgba(234, 191, 203, 0.18);
        border-color: var(--border);
      }

      .btn-primary {
        background: var(--blue);
        border-color: var(--blue);
        color: #ffffff;
      }

      .btn-primary:hover,
      .btn-primary:focus {
        background: #8f4377;
        border-color: #8f4377;
      }

      .btn-outline-primary {
        border-color: var(--mint);
        color: var(--mint);
      }

      .btn-outline-primary:hover {
        background: var(--mint);
        border-color: var(--mint);
        color: #ffffff;
      }

      .btn-outline-secondary {
        border-color: var(--ink);
        color: var(--ink);
      }

      .btn-outline-secondary:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: #ffffff;
      }

      .btn-outline-danger {
        border-color: var(--coral);
        color: var(--coral);
      }

      .btn-outline-danger:hover {
        background: var(--coral);
        border-color: var(--coral);
        color: #ffffff;
      }

      .form-control:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 0.2rem rgba(164, 80, 139, 0.18);
      }

      .form-label {
        color: var(--ink);
        font-weight: 600;
      }

      a {
        color: var(--blue);
      }

      a:hover {
        color: var(--mint);
      }

      .page-link {
        color: var(--blue);
      }

      .page-item.active .page-link {
        background-color: var(--mint);
        border-color: var(--mint);
      }

      .page-link:focus {
        box-shadow: 0 0 0 0.2rem rgba(95, 10, 135, 0.18);
      }

      .text-muted {
        color: rgba(47, 0, 79, 0.78) !important;
      }

      .alert-danger {
        background: var(--coral);
        border-color: var(--coral);
        color: var(--ink);
      }

      .alert-success {
        background: var(--mint);
        border-color: var(--mint);
        color: #ffffff;
      }

      .flash-stack {
        position: fixed;
        top: 0.9rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1090;
        width: min(92vw, 560px);
        pointer-events: none;
      }

      .flash-alert {
        pointer-events: auto;
        margin-bottom: 0.65rem;
        border: none;
        box-shadow: 0 0.75rem 2rem rgba(80, 81, 79, 0.18);
        animation: flashDrop 220ms ease-out;
      }

      .flash-alert.fade-out {
        opacity: 0;
        transform: translateY(-12px);
        transition: opacity 180ms ease, transform 180ms ease;
      }

      @keyframes flashDrop {
        from {
          opacity: 0;
          transform: translateX(-50%) translateY(-12px);
        }

        to {
          opacity: 1;
          transform: translateX(-50%);
        }
      }

      .badge {
        color: var(--ink);
      }

      .badge.bg-warning {
        background: var(--sun) !important;
      }

      .badge.bg-info {
        background: rgba(164, 80, 139, 0.16) !important;
      }

      .badge.bg-success {
        background: rgba(95, 10, 135, 0.16) !important;
      }

      .badge.bg-danger {
        background: rgba(234, 191, 203, 0.36) !important;
      }

      .navbar .text-muted,
      .navbar .small {
        color: rgba(255, 255, 255, 0.8) !important;
      }

      .navbar-brand {
        color: #ffffff !important;
      }

      .navbar {
        box-shadow: 0 0.5rem 1.25rem rgba(47, 0, 79, 0.12);
      }

      .navbar .container {
        padding-left: 1rem;
        padding-right: 1rem;
      }
    </style>
  </head>
  <body>
    <% const activePageFlashMessages = typeof pageFlashMessages !== 'undefined' ? pageFlashMessages : []; %>
    <% const activeFlashMessages = (flashMessages || []).concat(activePageFlashMessages); %>
    <% if (activeFlashMessages.length) { %>
      <div class="flash-stack">
        <% activeFlashMessages.forEach((flash) => { %>
          <div class="alert <%= flash.type === 'success' ? 'alert-success' : 'alert-danger' %> flash-alert mb-0" role="alert" data-flash>
            <%= flash.message %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <nav class="navbar navbar-expand-lg border-bottom">
      <div class="container">
        <a class="navbar-brand fw-semibold d-flex align-items-center" href="/">
          <img src="/unsentfavicon.svg" alt="Unsent logo" width="24" height="24" class="d-inline-block align-middle me-2" />
          <span style="color: var(--coral) !important;">Unsent</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
          <% if (currentUser) { %>
            <span class="text-muted small d-none d-md-inline"><%= currentUser.displayName %></span>
            <a href="/logout" class="btn btn-outline-secondary btn-sm">Logout</a>
          <% } else { %>
            <a href="/auth/google" class="btn btn-primary btn-sm">Sign in</a>
          <% } %>
        </div>
      </div>
    </nav>

    <main class="py-4">
      <div class="container">
        <%- body %>
      </div>
    </main>

    <script>
      (() => {
        const flashes = document.querySelectorAll("[data-flash]");

        flashes.forEach((flash) => {
          window.setTimeout(() => {
            flash.classList.add("fade-out");

            window.setTimeout(() => {
              flash.remove();
            }, 180);
          }, 3000);
        });
      })();
    </script>
  </body>
</html>
