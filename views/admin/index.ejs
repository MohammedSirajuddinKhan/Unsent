<div class="row">
  <div class="col-12 mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <h1 class="h4">Admin Dashboard</h1>
      <a href="/" class="btn btn-outline-secondary">Back to app</a>
    </div>
  </div>

  <div class="col-12 mb-4">
    <div class="card">
      <div class="card-body">
        <h2 class="h6">Users</h2>
        <div class="admin-users-grid mt-3">
          <% users.forEach(function(u){ %>
            <div class="user-card">
              <div style="flex:1">
                <div style="display:flex;align-items:center;gap:8px;">
                  <div style="font-weight:600"><%= u.displayName || u.email %></div>
                  <% if (u.isAdmin) { %><span class="badge bg-info">Admin</span><% } %>
                  <% if (u.isBanned) { %><span class="badge bg-danger">Banned</span><% } %>
                </div>
                <div class="small text-muted"><%= u.email %></div>
              </div>
              <div class="admin-actions text-end">
                <a href="/admin/users/<%= u._id %>" class="btn btn-sm btn-outline-secondary">Notes</a>
                <form method="POST" action="/admin/users/<%= u._id %>/toggle-admin" onsubmit="return confirm('Toggle admin role for this user?');">
                  <button class="btn btn-sm <%= u.isAdmin ? 'btn-outline-warning' : 'btn-outline-success' %>"><%= u.isAdmin ? 'Demote' : 'Promote' %></button>
                </form>
                <form method="POST" action="/admin/users/<%= u._id %>/toggle-ban" onsubmit="return confirm('Toggle ban for this user?');">
                  <button class="btn btn-sm <%= u.isBanned ? 'btn-outline-danger' : 'btn-outline-dark' %>"><%= u.isBanned ? 'Unban' : 'Ban' %></button>
                </form>
                <form method="POST" action="/admin/users/<%= u._id %>/delete" onsubmit="return confirm('Delete user and all their notes?');">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12">
    <div class="card mb-4 admin-dashboard">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <h2 class="h6">Notes</h2>
          <form class="d-flex" method="GET" action="/admin">
            <input name="q" value="<%= q || '' %>" class="form-control form-control-sm me-2" placeholder="Search title or body" />
            <button class="btn btn-sm btn-outline-primary">Search</button>
          </form>
        </div>

        <div class="table-responsive mt-3">
          <table class="table table-sm admin-notes-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>User</th>
                <th>Created</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% notes.forEach(function(n){ %>
                <tr>
                  <td><%= n.title %></td>
                  <td><%= n.user ? (n.user.displayName || n.user.email) : '—' %></td>
                  <td><%= new Date(n.createdAt).toLocaleString() %></td>
                  <td class="text-end">
                    <a href="/notes/<%= n._id %>" class="btn btn-sm btn-outline-primary">View</a>
                    <form method="POST" action="/admin/notes/<%= n._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this note?');">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <% if (totalPages && totalPages > 1) { %>
          <nav>
            <ul class="pagination pagination-sm">
              <% for (let p=1; p<=totalPages; p++) { %>
                <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="/admin?q=<%= encodeURIComponent(q||'') %>&page=<%= p %>"><%= p %></a></li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>
</div>
