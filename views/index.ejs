<% if (currentUser) { %>
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
		<div>
			<h1 class="h3 mb-1">My Notes</h1>
			<p class="text-muted mb-0">Signed in as <%= currentUser.displayName %></p>
		</div>
		<a href="/notes/new" class="btn btn-primary">Add Note</a>
	</div>

	<form method="GET" action="/" class="card card-body mb-4">
		<div class="row g-2 align-items-center">
			<div class="col-md-9">
				<input
					type="text"
					class="form-control"
					name="q"
					value="<%= search %>"
					placeholder="Search notes by title or content"
				/>
			</div>
			<div class="col-md-3 d-grid gap-2 d-md-flex">
				<button type="submit" class="btn btn-outline-primary flex-fill">Search</button>
				<% if (search) { %>
					<a href="/" class="btn btn-outline-secondary flex-fill">Reset</a>
				<% } %>
			</div>
		</div>
	</form>

	<% if (notes.length) { %>
		<div class="row g-3">
			<% notes.forEach((note) => { %>
				<div class="col-md-6 col-lg-4">
					<div class="card h-100 shadow-sm">
						<div class="card-body d-flex flex-column">
							<h2 class="h5 card-title"><%= note.title %></h2>
							<p class="text-muted flex-grow-1 mb-3">
								<%= note.body.length > 160 ? note.body.slice(0, 160) + "..." : note.body %>
							</p>
							<div class="d-flex flex-wrap gap-2">
								<a href="/notes/<%= note._id %>" class="btn btn-sm btn-outline-secondary">View</a>
								<a href="/notes/<%= note._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
								<form method="POST" action="/notes/<%= note._id %>?_method=DELETE" class="d-inline" onsubmit="return confirm('Delete this note?');">
									<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
								</form>
							</div>
						</div>
					</div>
				</div>
			<% }) %>
		</div>

		<% if (pagination && pagination.totalPages > 1) { %>
			<nav class="mt-4">
				<ul class="pagination flex-wrap">
					<li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
						<a class="page-link" href="<%= pagination.hasPrev ? '/?page=' + pagination.prevPage + (search ? '&q=' + encodeURIComponent(search) : '') : '#' %>">Previous</a>
					</li>
					<% pagination.pages.forEach((pageNumber) => { %>
						<li class="page-item <%= pageNumber === pagination.page ? 'active' : '' %>">
							<a class="page-link" href="/?page=<%= pageNumber %><%= search ? '&q=' + encodeURIComponent(search) : '' %>"><%= pageNumber %></a>
						</li>
					<% }) %>
					<li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
						<a class="page-link" href="<%= pagination.hasNext ? '/?page=' + pagination.nextPage + (search ? '&q=' + encodeURIComponent(search) : '') : '#' %>">Next</a>
					</li>
				</ul>
			</nav>
		<% } %>
	<% } else { %>
		<div class="card card-body text-center py-5">
			<h2 class="h5 mb-2">No notes yet</h2>
			<p class="text-muted mb-0">Create your first note to get started.</p>
		</div>
	<% } %>
<% } else { %>
	<div class="row justify-content-center py-5">
		<div class="col-lg-7">
			<div class="card shadow-sm">
				<div class="card-body p-4 p-md-5">
					<h1 class="h3 mb-3">Unsent | Saved, not sent.</h1>
					<p class="text-muted mb-4">Sign in with Google to create, search and manage your notes.</p>
					<a href="/auth/google" class="btn btn-primary">Continue with Google</a>
				</div>
			</div>
		</div>
	</div>
<% } %>