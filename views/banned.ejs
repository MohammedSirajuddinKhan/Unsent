<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <div class="mb-4">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#FDE7E9"/>
            <path d="M15 9L9 15" stroke="#B4234A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9 9l6 6" stroke="#B4234A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <h1 class="h4 text-danger">Your account has been banned</h1>
        <p class="text-muted mb-3">Access to this site has been revoked for your account.</p>

        <% if (user && user.email) { %>
          <p class="small text-muted">Account: <strong><%= user.email %></strong></p>
        <% } %>

        <div class="mt-3">
          <p class="mb-2">If you believe this is a mistake, contact an administrator:</p>
          <% if (adminEmails && adminEmails.length) { %>
            <ul class="list-unstyled">
              <% adminEmails.forEach(function(a){ %>
                <li><a href="mailto:<%= a %>"><%= a %></a></li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="small text-muted">(No admin contact configured)</p>
          <% } %>
        </div>

        <a href="/" class="btn btn-outline-danger mt-3">Return to home</a>
      </div>
    </div>
  </div>
</div>
